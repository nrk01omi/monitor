# Copy to .vscode/.env (gitignored) and fill in your Portainer access token.
# launch.json references .vscode/.env via "envFile" so values here override
# the inline "env" block in launch.json.

PORTAINER_API_KEY=ptr_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the URL when running locally (outside the NAS bridge net).
# On the NAS the compose default 172.17.0.2:9000 works because ollama-proxy
# joins Docker's default bridge. From a Windows dev box use the LAN IP.
# PORTAINER_URL=http://192.168.0.198:9000
# PORTAINER_ENDPOINT_ID=3
